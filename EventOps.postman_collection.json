                ""
              ]
            }
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "",
                  "if (response.access) {",
                  "  pm.environment.set(\"access_token\", response.access);",
                  "}",
                  "",
                  "if (response.refresh) {",
                  "  pm.environment.set(\"refresh_token\", response.refresh);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{user_username}}\",\n  \"password\": \"{{user_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/token/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "token",
                ""
              ]
            }
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "request": {
